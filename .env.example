# ── Database ─────────────────────────────────────────
POSTGRES_PASSWORD=
POSTGRES_USER=gbrain
POSTGRES_DB=gbrain

# ── Server ───────────────────────────────────────────
GBRAIN_PORT=3000
GBRAIN_ADMIN_SECRET=
GBRAIN_REF=latest

# ── LLM (enrichment / extraction / synthesis) ───────
# Any OpenAI-compatible endpoint. Leave empty to skip.
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ── Embedding ────────────────────────────────────────
# Pick one provider. deploy.sh will guide you interactively.
#
# OpenAI:
#   OPENAI_API_KEY=sk-...
#   EMBEDDING_GBRAIN_SPEC=openai:text-embedding-3-small
#   EMBEDDING_DIM=1536
#
# OpenAI-compatible (custom URL):
#   OPENAI_API_KEY=your-key
#   OPENAI_BASE_URL=https://your-provider.com/v1
#   EMBEDDING_GBRAIN_SPEC=openai:text-embedding-3-small
#   EMBEDDING_DIM=1536
#
# ZeroEntropy:
#   ZEROENTROPY_API_KEY=...
#   EMBEDDING_GBRAIN_SPEC=zeroentropy:zembed-1
#   EMBEDDING_DIM=1280
#
# Voyage AI:
#   VOYAGE_API_KEY=...
#   EMBEDDING_GBRAIN_SPEC=voyage:voyage-3
#   EMBEDDING_DIM=1024
#
# Ollama (local Docker):
#   OLLAMA_ENABLED=true
#   OLLAMA_EMBED_MODEL=nomic-embed-text
#   EMBEDDING_GBRAIN_SPEC=ollama:nomic-embed-text
#   EMBEDDING_DIM=768
#
# Ollama (connect to host):
#   OLLAMA_HOST=http://host.docker.internal:11434
#   EMBEDDING_GBRAIN_SPEC=ollama:nomic-embed-text
#   EMBEDDING_DIM=768
