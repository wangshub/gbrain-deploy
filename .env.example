# ── Required ──────────────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-password
GBRAIN_ADMIN_SECRET=change-me-to-a-strong-secret

# ── Embedding Provider (pick one, set its API key) ───
# Default: zeroentropy (zero cost setup at zeroentropy.dev)
ZEROENTROPY_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# ── Embedding Model (optional, auto-detected from keys) ──
# GBRAIN_EMBEDDING_MODEL=zeroentropy:zembed-1
# GBRAIN_EMBEDDING_DIMENSIONS=1280

# ── Postgres ─────────────────────────────────────────
# POSTGRES_DB=gbrain
# POSTGRES_USER=gbrain

# ── gbrain ───────────────────────────────────────────
# GBRAIN_PORT=3000
# GBRAIN_REF=latest            # git ref: tag, branch, or commit
